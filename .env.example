# Copiez ce fichier vers .env et renseignez vos valeurs

# === MongoDB ===
MONGODB_LOCAL_URI=mongodb://localhost:27017/libreville_eats
MONGODB_ATLAS_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/libreville-eats?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/libreville_eats

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === Serveur ===
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# === JWT ===
JWT_SECRET=changez_cette_cle_secrete_en_production
JWT_EXPIRE=7d

# === Journalisation ===
LOG_LEVEL=debug
