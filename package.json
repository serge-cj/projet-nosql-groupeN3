{
  "name": "libreville-eats-backend",
  "version": "1.0.0",
  "description": "Libreville Eats — API de livraison de repas à Libreville",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "seed": "node scripts/seed/index.js",
    "seed:clean": "node scripts/cleanup.js",
    "indexes": "node scripts/indexes/create-indexes.js",
    "aggregate:restaurant-stats": "node scripts/aggregations/restaurant-order-stats.js",
    "aggregate:deliverer-metrics": "node scripts/aggregations/deliverer-performance-metrics.js",
    "aggregate:revenue-analysis": "node scripts/aggregations/revenue-analysis.js",
    "aggregate:all": "node scripts/aggregations/index.js",
    "demo:seed-orders": "node scripts/demo/seed-commandes-demo.js",
    "demo:mongosh": "mongosh \"${MONGODB_URI:-mongodb://localhost:27017/libreville_eats}\" --file scripts/demo/soutenance-live.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "author": "Groupe 3 — Libreville Eats",
  "license": "ISC",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "mongoose": "^8.11.0",
    "nodemailer": "^6.9.7",
    "pino": "^8.17.2",
    "pino-http": "^8.6.1",
    "pino-pretty": "^10.3.1",
    "redis": "^4.6.12",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.4"
  }
}
